generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  AGENT
  ADMIN
}

enum OrderType {
  B2B
  B2C
}

enum PaymentType {
  PREPAID
  COD
}

enum OrderStatus {
  PENDING
  CONFIRMED
  ASSIGNED
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  RESCHEDULED
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  password     String
  phone        String?
  role         Role     @default(CUSTOMER)
  createdAt    DateTime @default(now())

  orders       Order[]  @relation("CustomerOrders")
  createdOrders Order[] @relation("CreatedByAdmin")
  agent        Agent?
}

model Zone {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  areas     Area[]
  rateCards RateCard[]
  pickupOrders  Order[] @relation("PickupZone")
  dropOrders    Order[] @relation("DropZone")
  agents        Agent[]
}

model Area {
  id       String @id @default(cuid())
  pincode  String @unique
  city     String
  state    String
  zoneId   String
  zone     Zone   @relation(fields: [zoneId], references: [id])
}

model RateCard {
  id            String    @id @default(cuid())
  zoneId        String
  zone          Zone      @relation(fields: [zoneId], references: [id])
  orderType     OrderType
  isIntraZone   Boolean
  baseRate      Float     // per kg
  codSurcharge  Float     // flat amount per order

  @@unique([zoneId, orderType, isIntraZone])
}

model Agent {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  zoneId      String
  zone        Zone     @relation(fields: [zoneId], references: [id])
  isAvailable Boolean  @default(true)
  latitude    Float?
  longitude   Float?
  createdAt   DateTime @default(now())

  orders      Order[]
}

model Order {
  id              String      @id @default(cuid())
  customerId      String
  customer        User        @relation("CustomerOrders", fields: [customerId], references: [id])
  createdById     String?
  createdBy       User?       @relation("CreatedByAdmin", fields: [createdById], references: [id])

  // Addresses
  pickupAddress   String
  pickupPincode   String
  dropAddress     String
  dropPincode     String

  // Package
  length          Float
  breadth         Float
  height          Float
  actualWeight    Float
  volumetricWeight Float
  chargeableWeight Float

  // Classification
  orderType       OrderType
  paymentType     PaymentType

  // Zone detection
  pickupZoneId    String?
  pickupZone      Zone?       @relation("PickupZone", fields: [pickupZoneId], references: [id])
  dropZoneId      String?
  dropZone        Zone?       @relation("DropZone", fields: [dropZoneId], references: [id])
  isIntraZone     Boolean?

  // Pricing
  baseCharge      Float
  codSurcharge    Float       @default(0)
  totalCharge     Float

  // Assignment
  agentId         String?
  agent           Agent?      @relation(fields: [agentId], references: [id])

  // Status
  status          OrderStatus @default(PENDING)

  // Reschedule
  rescheduledDate DateTime?
  failureReason   String?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  trackingLogs    TrackingLog[]
}

model TrackingLog {
  id        String      @id @default(cuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id])
  status    OrderStatus
  note      String?
  actorId   String?
  actorRole Role?
  createdAt DateTime    @default(now())
}
